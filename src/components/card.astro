---
import AstroImage from "@/components/astro-image.astro";

interface Props {
  href: string;
  /** Main image */
  imgSrc: string;
  imgAlt: string;
  /** Top line (bold) */
  title: string;
  /** Second line (muted) */
  subtitle?: string;
  /** Optional rating (0–10) shown as a corner badge */
  score?: number;
  /** Optional unique transition name */
  transitionName?: string;
  /** Aspect ratio of the cover frame */
  aspectClass?: string;
  /** Extra classes for the outer anchor */
  class?: string;
  /** Accessible label for the link */
  ariaLabel?: string;
}

const {
  href,
  imgSrc,
  imgAlt,
  title,
  subtitle,
  score,
  transitionName,
  aspectClass = "aspect-[2/3]",
  class: anchorClass = "",
  ariaLabel,
} = Astro.props as Props;
---

<a href={href} class={`group media-card flex flex-col ${anchorClass}`} aria-label={ariaLabel ?? title}>
  <div class={`media-frame ${aspectClass}`}>
    <div transition:name={transitionName} class="h-full w-full">
      <AstroImage src={imgSrc} alt={imgAlt} width={400} height={600} />
    </div>

    {
      score !== undefined && (
        <div class="absolute top-1.5 right-1.5 bg-black/60 px-1.5 py-0.5 text-xs font-semibold text-white tabular-nums backdrop-blur-sm">
          {score}
        </div>
      )
    }
  </div>

  <div class="px-0.5 pt-2.5">
    <p class="truncate text-sm font-medium text-white/90">{title}</p>
    {subtitle && <p class="truncate text-xs text-white/50">{subtitle}</p>}
  </div>
</a>
