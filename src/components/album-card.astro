---
interface Props {
  href: string;
  imgSrc: string;
  imgAlt: string;
  album: string;
  artist: string;
  score?: number;
  transitionName?: string;
  anchorClass?: string;
}

const { href, imgSrc, imgAlt, album, artist, score, transitionName, anchorClass = "" } = Astro.props as Props;
---

<a href={href} class={`group media-card flex flex-col ${anchorClass}`} aria-label={`${album} by ${artist}`}>
  <div class="relative aspect-square overflow-hidden bg-zinc-900">
    <!-- Blurred background - fills the square for non-square cover art -->
    <div
      class="absolute inset-0"
      style={{
        backgroundImage: `url(${imgSrc})`,
        backgroundSize: "cover",
        backgroundPosition: "center",
        backgroundRepeat: "no-repeat",
        transform: "scale(1.06)",
        filter: "blur(7px) saturate(60%) brightness(1.2)",
      }}
      aria-hidden="true"
    >
    </div>

    <div class="absolute inset-0 bg-linear-to-r from-black/20 via-transparent to-black/20 mix-blend-overlay"></div>

    <!-- Main art -->
    <div transition:name={transitionName} class="relative z-10 flex h-full w-full items-center justify-center">
      <img
        src={imgSrc}
        alt={imgAlt}
        class="max-h-full max-w-full object-contain"
        loading="lazy"
        decoding="async"
        style="display: block;"
      />
    </div>

    <!-- Subtle vignette -->
    <div class="pointer-events-none absolute inset-0 bg-linear-to-br from-black/10 to-black/0"></div>

    <!-- Score overlay - appears on hover -->
    {
      score !== undefined && (
        <div class="absolute inset-0 z-20 flex items-center justify-center bg-black/40 opacity-0 backdrop-blur-sm transition-all duration-300 ease-out group-hover:opacity-100">
          <div class="flex flex-col items-center gap-1">
            <div class="text-5xl font-light tracking-tighter text-white md:text-6xl">{score}</div>
            <div class="h-px w-12 bg-white/40" />
            <div class="text-sm font-light tracking-wide text-white/80 md:text-base">10</div>
          </div>
        </div>
      )
    }
  </div>

  <div class="px-0.5 pt-2.5">
    <p class="truncate text-sm font-medium text-white/90">{album}</p>
    <p class="truncate text-xs text-white/50">{artist}</p>
  </div>
</a>
