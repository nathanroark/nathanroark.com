---
import ArrowRight from "@/components/icons/arrow-right.astro";

interface Props {
  /** Section / page title */
  title: string;
  /** Optional link target — renders a "View all" affordance when present */
  href?: string;
  /** Small muted label on the right (e.g. an item count) */
  meta?: string;
  /** Tag for the heading element */
  as?: "h1" | "h2";
}

const { title, href, meta, as: Tag = "h2" } = Astro.props as Props;
const sizeClass = Tag === "h1" ? "text-4xl md:text-5xl" : "text-2xl md:text-3xl";
---

<div class="flex items-end justify-between gap-4 border-b border-white/10 pb-3">
  <Tag class={`font-bold tracking-tight ${sizeClass}`}>
    {
      href ? (
        <a href={href} class="transition-opacity hover:opacity-70">
          {title}
        </a>
      ) : (
        title
      )
    }
  </Tag>

  {
    href ? (
      <a
        href={href}
        class="group/sh inline-flex shrink-0 items-center gap-1 pb-1 text-sm font-medium text-white/55 transition-colors hover:text-white"
        aria-label={`View all ${title}`}
      >
        View all
        <ArrowRight size={16} class="transition-transform duration-300 group-hover/sh:translate-x-0.5" />
      </a>
    ) : (
      meta && <span class="shrink-0 pb-1.5 text-sm text-white/40">{meta}</span>
    )
  }
</div>
